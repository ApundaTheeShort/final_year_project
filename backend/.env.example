DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True

# Comma-separated hosts allowed to serve this Django app.
ALLOWED_HOSTS=127.0.0.1,localhost

# Required when deploying behind HTTPS on a real domain.
# Example: https://freshhaul.example.com,https://www.freshhaul.example.com
CSRF_TRUSTED_ORIGINS=

# Set these to True in production when the app is served over HTTPS.
USE_SECURE_COOKIES=False
SECURE_SSL_REDIRECT=False
ENABLE_HSTS=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# API throttling defaults. Tighten or relax based on real traffic patterns.
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=300/minute

# Database settings. Leave empty to fall back to local sqlite.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# Map integrations.
MAPS_USER_AGENT=final-year-project-backend/1.0
MAPS_TIMEOUT_SECONDS=10
NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_LOOKUP_URL=https://nominatim.openstreetmap.org/lookup
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
OSRM_BASE_URL=https://router.project-osrm.org

# Mail delivery.
# Use Brevo SMTP in production, or leave EMAIL_HOST empty for console email in local development.
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=FreshHaul <no-reply@example.com>
SERVER_EMAIL=
